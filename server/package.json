{
  "name": "smart-street-light-server",
  "version": "2.0.0",
  "description": "智慧路灯管理系统 - TypeScript后端API服务",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "init-db": "node dist/database/init_db.js",
    "migrate": "node migrate-alert-level.cjs"
  },
  "dependencies": {
