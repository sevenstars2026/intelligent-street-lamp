# 环境配置
NODE_ENV=development
PORT=3000

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=smart_lamp

# MQTT配置
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=
# 是否模拟硬件响应（开发测试时设为true，接入真实硬件后设为false）
MQTT_SIMULATE_HARDWARE=true

# Mock JWT配置（当前版本仅保留占位，后续接入真实认证时使用）
JWT_SECRET=your-secret-key
JWT_EXPIRES_IN=24h
