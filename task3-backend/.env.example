# 环境配置
NODE_ENV=development
PORT=3000

# 数据库配置（待任务2提供）
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=smart_lamp

# Redis配置（待任务2提供）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# MQTT配置（待任务2提供）
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# JWT配置（待任务2提供）
JWT_SECRET=your-secret-key
JWT_EXPIRES_IN=24h

# 邮件配置
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# 心跳超时倍数
HEARTBEAT_TIMEOUT_MULTIPLIER=3

# 离线检测定时任务间隔（秒）
OFFLINE_CHECK_INTERVAL=30

# 告警升级检测定时任务间隔（秒）
ALARM_UPGRADE_CHECK_INTERVAL=600

# 数据聚合定时任务（cron表达式）
DATA_AGGREGATION_CRON=0 * * * *

# 数据清理定时任务（cron表达式）
DATA_CLEANUP_CRON=0 0 * * *
